# Environment
NODE_ENV=development

# JWT Configuration (MUST match PHP backend)
# This is the same secret used by your PHP backend for JWT signing
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Application URL
# Development: http://localhost:3000
# Production: https://your-auth-server.vercel.app
VERCEL_URL=http://localhost:3000

# Google OAuth Credentials
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# PHP Backend Integration
# Development: http://localhost:8000/api/v1
# Production: https://your-domain.com/api/v1
PHP_API_URL=http://localhost:8000/api/v1

# PHP Authentication Secret (for better-auth ↔ PHP communication)
# MUST match BETTER_AUTH_SECRET in PHP backend .env
PHP_AUTH_SECRET=ded9844c2ec315d50b6699b8dd06b0b294003a59f8268cdbd8257e086d2a542d
